{
  "name": "lightningcss-plugin-extended-colors-monorepo",
  "private": true,
  "description": "LightningCSS plugin that adds support for more named colors",
  "author": "Karey Higuera <kbravh>",
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "packages/*"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kbravh/lightningcss-plugin-extended-colors.git"
  },
  "bugs": {
    "url": "https://github.com/kbravh/lightningcss-plugin-extended-colors/issues"
  },
  "homepage": "https://github.com/kbravh/lightningcss-plugin-extended-colors#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "lint": "biome check",
    "format": "biome format",
    "typecheck": "tsc --noEmit",
    "check": "turbo run lint format typecheck",
    "fix": "biome check --write && biome format --write",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish",
    "upgrade": "npx npm-check-updates -i --format group"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "@rslib/core": "^0.19.6",
    "@types/node": "^25.3.0",
    "@vitest/coverage-v8": "^4.0.18",
    "lightningcss": "^1.31.1",
    "linkedom": "^0.18.12",
    "turbo": "^2.8.10",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
