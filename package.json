{
  "name": "lightningcss-plugin-extended-colors",
  "description": "LightningCSS plugin that adds support for more named colors (Crayola, Encycolorpedia, Pantone, etc.)",
  "author": "Karey Higuera <kbravh>",
  "version": "1.0.0",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kbravh/lightningcss-plugin-extended-colors.git"
  },
  "bugs": {
    "url": "https://github.com/kbravh/lightningcss-plugin-extended-colors/issues"
  },
  "homepage": "https://github.com/kbravh/lightningcss-plugin-extended-colors#readme",
  "keywords": [
    "lightningcss",
    "lightningcss-plugin",
    "css",
    "colors",
    "named-colors",
    "crayola",
    "encycolorpedia",
    "lego"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "rslib build",
    "check": "biome check --write",
    "dev": "rslib build --watch",
    "format": "biome format --write",
    "lint": "biome check",
    "test": "vitest run",
    "prepublishOnly": "npm run lint && npm run build && npm test",
    "upgrade": "npx npm-check-updates -i --format group"
  },
  "peerDependencies": {
    "lightningcss": "^1.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@rslib/core": "^0.5.2",
    "@types/node": "^22.8.1",
    "lightningcss": "^1.29.1",
    "linkedom": "^0.18.9",
    "typescript": "^5.7.3",
    "vitest": "^3.0.7"
  }
}
