{
  "name": "lightningcss-plugin-extended-colors-monorepo",
  "private": true,
  "description": "LightningCSS plugin that adds support for more named colors",
  "author": "Karey Higuera <kbravh>",
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kbravh/lightningcss-plugin-extended-colors.git"
  },
  "bugs": {
    "url": "https://github.com/kbravh/lightningcss-plugin-extended-colors/issues"
  },
  "homepage": "https://github.com/kbravh/lightningcss-plugin-extended-colors#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "npm run build --workspaces",
    "check": "biome check && biome format && tsc --noEmit",
    "fix": "biome check --write && biome format --write",
    "test": "npm run test --workspace=lightningcss-plugin-extended-colors",
    "test:coverage": "npm run test:coverage --workspace=lightningcss-plugin-extended-colors",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm run build && changeset publish",
    "upgrade": "npx npm-check-updates -i --format group"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.13",
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "@rslib/core": "^0.19.3",
    "@types/node": "^25.0.10",
    "@vitest/coverage-v8": "^4.0.18",
    "lightningcss": "^1.31.1",
    "linkedom": "^0.18.12",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
