{
  "name": "lightningcss-plugin-extended-colors",
  "description": "LightningCSS plugin that adds support for more named colors (Crayola, Encycolorpedia, Pantone, etc.)",
  "author": "Karey Higuera <kbravh>",
  "version": "2.0.0",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kbravh/lightningcss-plugin-extended-colors.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/kbravh/lightningcss-plugin-extended-colors/issues"
  },
  "homepage": "https://github.com/kbravh/lightningcss-plugin-extended-colors#readme",
  "keywords": [
    "lightningcss",
    "lightningcss-plugin",
    "css",
    "colors",
    "named-colors"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "rslib build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "lightningcss": "^1.0.0"
  },
  "devDependencies": {
    "@lightningcss-plugin-extended-colors/crayola": "^1.0.0",
    "@lightningcss-plugin-extended-colors/encycolorpedia": "^1.0.0",
    "@lightningcss-plugin-extended-colors/lego": "^1.0.0",
    "@rslib/core": "^0.20.0",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "lightningcss": "^1.31.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
